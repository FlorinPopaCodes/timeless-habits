{
  "enabledPlugins": {
    "cloudflare@cloudflare": true
  },
  "permissions": {
    "allow": [
      "Bash(bun run lint)",
      "Bash(bun run lint:fix:*)",
      "Bash(bun test:*)",
      "Bash(bun run typecheck:*)",
      "Bash(bun --version:*)",
      "Bash(tsc --version:*)",
      "Bash(ls:*)",
      "Bash(pwd:*)",
      "Bash(find:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(wc:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(cat:*)",
      "Bash(tree:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git remote:*)",
      "Bash(git tag:*)",
      "Bash(git stash list:*)",
      "Bash(git rev-parse:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh run view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run logs:*)",
      "Bash(gh repo view:*)",
      "Bash(gh api:*)",
      "WebFetch(domain:developers.cloudflare.com)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:docs.github.com)",
      "WebFetch(domain:cli.github.com)",
      "WebFetch(domain:hono.dev)",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__get-library-docs",
      "mcp__plugin_cloudflare-toolkit_cloudflare-docs__search_cloudflare_documentation"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // .tool_response.filePath' | { read -r f; echo \"$f\" | grep -qE '\\.ts$' && bunx biome check --write \"$f\"; } 2>/dev/null || true",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
